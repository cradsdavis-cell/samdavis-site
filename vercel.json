{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    { "path": "/api/cron/graduate-check", "schedule": "0 23 * * *" }
  ],
  "redirects": [
    {
      "source": "/book/ea-basic-build",
      "destination": "/book/discovery",
      "permanent": true
    },
    { "source": "/onepager", "destination": "/offer", "permanent": true },
    { "source": "/build", "destination": "/offer", "permanent": true },
    { "source": "/build-onepager", "destination": "/offer", "permanent": true }
  ],
  "rewrites": [
    { "source": "/account/login", "destination": "/account/login.html" },
    { "source": "/account/verify", "destination": "/account/verify.html" },
    { "source": "/account/set-password", "destination": "/account/set-password.html" },
    { "source": "/account", "destination": "/api/account" },
    { "source": "/account/", "destination": "/api/account" },
    { "source": "/account/sessions", "destination": "/api/account/sessions" },
    { "source": "/account/packs", "destination": "/api/account/packs" },
    { "source": "/account/subscription", "destination": "/api/account/subscription" },
    { "source": "/account/profile", "destination": "/api/account/profile" },
    { "source": "/account/profile/edit", "destination": "/api/account/profile-edit" },
    { "source": "/account/onboarding", "destination": "/api/account/onboarding" },
    { "source": "/account/admin", "destination": "/api/account/admin" },
    { "source": "/account/admin/", "destination": "/api/account/admin" },
    { "source": "/account/admin/client", "destination": "/api/account/admin/client" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    },
    {
      "source": "/api/stripe/webhook",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
